{
  "schemaVersion": 1,
  "id": "aqua-translate",
  "version": "${version}",
  "name": "AquaClient Translator",
  "description": "Translates signs and chat messages using Google Translate.",
  "authors": [
    "Aquific"
  ],
  "contact": {
    "discord": "https://discord.gg/3JgZcuyZUp"
  },
  "icon": "assets/template/icon.png",
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "com.example.addon.AquaTranslate"
    ]
  },
  "custom": {
    "meteor-client:color": "0,200,255",
    "modmenu": {
      "parent": {
        "id": "aquaclient"
      }
    }
  },
  "depends": {
    "java": ">=21",
    "minecraft": ["${mc_version}"],
    "aquaclient": "*"
  }
}
